{
  "name": "mtmi",
  "version": "0.0.14",
  "keywords": [
    "chat",
    "mtmi",
    "stream",
    "twitch"
  ],
  "license": "ISC",
  "author": "ManzDev",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "browser": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "default": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "update-badges": "node scripts/getGlobalBadges.js",
    "dev": "vite",
    "node": "tsdown --watch src/index.ts",
    "build": "tsdown",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "lint": "oxlint src",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "gh-pages": "^6.3.0",
    "jsdoc": "^4.0.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
