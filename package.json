{
  "name": "mtmi",
  "version": "0.0.8",
  "type": "module",
  "module": "dist/mtmi.js",
  "types": "dist/mtmi.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mtmi.js",
      "require": "./dist/mtmi.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "node": "tsdown --watch src/mtmi.ts",
    "build": "rm -f dist/mtmi.* && tsdown --format esm,cjs --dts src/mtmi.ts src/mtmi.ts",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "eslint-config-manzdev": "^0.0.3",
    "gh-pages": "^6.3.0",
    "jsdoc": "^4.0.4",
    "tsdown": "^0.14.1",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "keywords": [],
  "license": "ISC"
}
