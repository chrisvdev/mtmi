{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",  // reemplaza "Node"
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]            // reemplaza baseUrl + paths
    },
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "exclude": [
    "dist", "docs", "sandbox", "scripts", "public",
    "vite.config.js", "node_modules",
    "**/*.test.js", "**/*.test.ts",
    "**/*.spec.js", "**/*.spec.ts",
    "tsdown.config.ts"
  ],
  "references": [
    { "path": "./tsconfig.node.json" }
  ]
}
